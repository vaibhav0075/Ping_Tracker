{
  "name": "ping-tracker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"next dev\" \"tsx watch workers/ping-worker.ts\"",
    "dev:web": "next dev",
    "dev:worker": "tsx watch workers/ping-worker.ts",
    "build": "next build",
    "start": "concurrently \"next start\" \"tsx workers/ping-worker.ts\"",
    "start:web": "next start",
    "start:worker": "tsx workers/ping-worker.ts",
    "lint": "eslint"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.5.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.511.0",
    "mongoose": "^8.15.1",
    "next": "^16.2.7",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.3",
    "ping": "^0.4.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.56.4",
    "recharts": "^2.15.3",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.7",
    "@types/node": "^22.15.21",
    "@types/nodemailer": "^6.4.17",
    "@types/ping": "^0.4.4",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "concurrently": "^9.1.2",
    "eslint": "^9.27.0",
    "eslint-config-next": "^16.2.7",
    "tailwindcss": "^4.1.7",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}

# MongoDB
# Local development
# MONGODB_URI=mongodb://localhost:27017/ping-tracker
# MongoDB Atlas (update with your cluster credentials)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/ping-tracker?retryWrites=true&w=majority

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Ping Tracker" <your-email@gmail.com>

# Worker Configuration
PING_INTERVAL_MS=1000
MAX_CONCURRENT_PINGS=20
PING_HISTORY_RETENTION_DAYS=30

# Optional: Worker health port
WORKER_HEALTH_PORT=3001
